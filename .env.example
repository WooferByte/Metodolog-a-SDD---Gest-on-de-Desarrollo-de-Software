# Database Configuration
# For Docker Compose (recommended):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/foodstore_db
# For native PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/foodstore_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=foodstore_db
SEED_DATABASE=true

# JWT Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MercadoPago Configuration (Payment Gateway)
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_ENV=development

# Application
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
