# Application
ENV=development
APP_NAME=Food Store API
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foodstore
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security & JWT
SECRET_KEY=your-secret-key-minimum-256-bits-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_COST=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MercadoPago
MP_ACCESS_TOKEN=TEST-your-mercadopago-access-token
MERCADOPAGO_PUBLIC_KEY=TEST-your-mercadopago-public-key

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=900
